# Device connection credentials
# Copy this file to .env.local and fill in your values.
# .env.* files are gitignored and will not be committed.
#
# Usage: source .env.local

# BPI RV2 device (or any sctl device)
BPI_HOST=192.168.1.100
BPI_PORT=1337
BPI_URL=http://192.168.1.100:1337
BPI_KEY=your-api-key-here

# Relay server (used by rundev.sh relay commands)
# Set these via: ./rundev.sh relay setup <host>
# RELAY_HOST=relay.example.com
# RELAY_URL=https://relay.example.com
# RELAY_TUNNEL_KEY=your-tunnel-key-here
# RELAY_API_KEY=your-relay-admin-key-here
