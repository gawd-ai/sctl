{
  "name": "sctlin",
  "version": "0.2.0",
  "description": "Web interface for sctl with interactive AI and terminal",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./src/lib/components/index.ts",
      "svelte": "./src/lib/components/index.ts",
      "default": "./dist/components/index.js"
    },
    "./types": {
      "types": "./src/lib/types/index.ts",
      "svelte": "./src/lib/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./src/lib/utils/index.ts",
      "svelte": "./src/lib/utils/index.ts",
      "default": "./dist/utils/index.js"
    },
    "./widgets": {
      "types": "./src/lib/widgets/index.ts",
      "svelte": "./src/lib/widgets/index.ts",
      "default": "./dist/widgets/index.js"
    }
  },
  "files": [
    "dist",
    "src/lib",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node -e \"require('fs').writeFileSync('build/package.json', '{\\\"type\\\":\\\"module\\\"}\\n')\" && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "flowbite-svelte": "^0.47.0",
    "flowbite-svelte-icons": "^2.0.0",
    "gawdux": "github:gawd-ai/gawdux",
    "jsdom": "^28.1.0",
    "publint": "^0.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "terminal",
    "xterm",
    "sctl",
    "pty",
    "websocket"
  ],
  "license": "GPL-3.0-only"
}
